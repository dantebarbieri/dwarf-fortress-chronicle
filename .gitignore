# Dwarf Fortress Chronicle - .gitignore

# ============================================================================
# Core Game Data (ignore everything in data/)
# ============================================================================
# The data/ directory contains game files, saves, sounds, and vanilla content
# that shouldn't be version controlled
data/

# ============================================================================
# Game Binaries & Libraries
# ============================================================================
# Executables and DLLs should not be version controlled
*.exe
*.dll


# ============================================================================
# Game-Generated Files (ignore at root level)
# ============================================================================
# These are generated by Dwarf Fortress during gameplay
errorlog.txt
gamelog.txt

# Legends XML exports (too large for Git, can be regenerated from saves)
# Keep XML fragments for testing scripts
region*-legends.xml

# ============================================================================
# Python Environment & Cache
# ============================================================================
# For the planned python scripts folder
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ============================================================================
# IDE & Editor Files
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================================
# Temporary & Backup Files
# ============================================================================
*.bak
*.tmp
*.temp
~*

# ============================================================================
# Keep Chronicle Files (explicit inclusions)
# ============================================================================
# These patterns ensure chronicle content is tracked even if other patterns match
!chronicle/
!chronicle/*.md

# Note: By default, files are tracked unless explicitly ignored above.
# XML test fragments, .md files, and most .txt files will be tracked.
# Ignored: region*-legends.xml, errorlog.txt, gamelog.txt, and everything in data/
